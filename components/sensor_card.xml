<component>
    <api>
        <prop name="title" type="string" default="Sensor 01"/>
        <prop name="zone" type="string" default="Linha A"/>
        <prop name="temperature" type="string" default="25.0 C"/>
        <prop name="delta" type="string" default="+0.0 C"/>
        <prop name="status" type="string" default="Estavel"/>
        <prop name="progress" type="int" default="50"/>
        <prop name="accent" type="color" default="0x34d6df"/>
    </api>

    <styles>
        <style name="indicator_fill"
               bg_color="$accent" bg_opa="100%"
               radius="999"/>
    </styles>

    <previews>
        <preview name="card"
                 width="320" height="180"
                 style_bg_color="0x06111c" style_pad_all="16"/>
    </previews>

    <view extends="lv_obj" width="280" height="150" flex_flow="column" style_pad_row="12">
        <style name="panel_card"/>

        <lv_obj width="100%" height="content"
                flex_flow="row"
                style_bg_opa="0%" style_border_width="0" style_pad_all="0"
                style_pad_column="12" style_flex_main_place="space_between">
            <lv_obj width="content" height="content"
                    flex_flow="row"
                    style_bg_opa="0%" style_border_width="0" style_pad_all="0"
                    style_pad_column="10">
                <lv_obj width="14" height="14"
                        style_bg_color="$accent" style_bg_opa="100%"
                        style_radius="999" style_border_width="0"/>
                <lv_obj width="content" height="content"
                        flex_flow="column"
                        style_bg_opa="0%" style_border_width="0" style_pad_all="0"
                        style_pad_row="4">
                    <lv_label text="$title" style_text_color="0xf5fbff"/>
                    <lv_label text="$zone">
                        <style name="muted_text"/>
                    </lv_label>
                </lv_obj>
            </lv_obj>

            <lv_obj width="content" height="content">
                <style name="pill_soft"/>
                <lv_label text="$status" style_text_color="$accent"/>
            </lv_obj>
        </lv_obj>

        <lv_obj width="100%" height="content"
                flex_flow="row"
                style_bg_opa="0%" style_border_width="0" style_pad_all="0"
                style_flex_main_place="space_between">
            <lv_label text="$temperature" style_text_color="0xffffff" style_text_letter_space="1"/>
            <lv_label text="$delta" style_text_color="$accent"/>
        </lv_obj>

        <lv_bar width="100%" height="10" value="$progress"
                style_bg_color="0x142334" style_bg_opa="100%"
                style_radius="999" style_border_width="0">
            <style name="indicator_fill" selector="indicator"/>
        </lv_bar>

        <lv_obj width="100%" height="content"
                flex_flow="row"
                style_bg_opa="0%" style_border_width="0" style_pad_all="0"
                style_flex_main_place="space_between">
            <lv_label text="Faixa segura 18 a 32 C">
                <style name="muted_text"/>
            </lv_label>
            <lv_label text="amostra viva">
                <style name="muted_text"/>
            </lv_label>
        </lv_obj>
    </view>
</component>
