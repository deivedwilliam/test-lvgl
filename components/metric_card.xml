<component>
    <api>
        <prop name="label" type="string" default="Media"/>
        <prop name="value" type="string" default="25.3 C"/>
        <prop name="note" type="string" default="Resumo"/>
        <prop name="accent" type="color" default="0x34d6df"/>
    </api>

    <previews>
        <preview name="dark_card"
                 width="240" height="140"
                 style_bg_color="0x06111c" style_pad_all="16"/>
    </previews>

    <view extends="lv_obj" width="206" height="124" flex_flow="column" style_pad_row="10">
        <style name="panel_card"/>

        <lv_obj width="48" height="6"
                style_bg_color="$accent" style_bg_opa="100%"
                style_radius="999" style_border_width="0"/>

        <lv_label text="$label">
            <style name="muted_text"/>
        </lv_label>

        <lv_label text="$value" style_text_color="0xffffff"/>

        <lv_label text="$note" width="100%" long_mode="wrap">
            <style name="muted_text"/>
        </lv_label>
    </view>
</component>
